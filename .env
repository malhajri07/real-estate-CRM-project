# Development Environment - Copy to .env for local development
# cp .env.dev.example .env

# Database (matches docker-compose.dev and docker-compose.devcontainer)
# Use postgres:postgres if running Docker; use your macOS user if using local PostgreSQL
DATABASE_URL="postgresql://mohammedalhajri@localhost:5432/real_estate_crm?schema=public"

# Redis (optional - only if using Redis features)
REDIS_URL="redis://localhost:6379"

# Security (use dev values - never in production)
JWT_SECRET="dev-jwt-secret-change-in-production"
SESSION_SECRET="dev-session-secret-change-in-production"

# Server
PORT=3000
NODE_ENV=development

# Optional: Google Maps (for map features)
# VITE_GOOGLE_MAPS_API_KEY=your_key_here
# GOOGLE_MAPS_API_KEY=your_key_here

# Optional: Twilio (for SMS in pool)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
