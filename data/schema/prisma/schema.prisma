// NOTE: All findMany queries should use a default limit. See apps/api/src/utils/pagination.ts

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Imported broker / agency account records (REGA-style account numbers).
/// Distinct from `users` — these are pre-existing entity registrations.
model accounts {
  id            String    @id @default(uuid())
  firstNameAr   String?
  lastNameAr    String?
  roleType      String?
  accountIdType String?
  accountNumber String    @unique
  parentAccount String?
  usernameEn    String?
  mobile        String?
  createDate    DateTime?
  expiryDate    DateTime?
  status        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([parentAccount])
  @@index([status])
  @@index([createdAt])
}

/// Per-agent extended profile — REGA license, FAL details, specialties, bio.
/// 1:1 with `users` (only users with INDIV_AGENT or CORP_AGENT role have one).
/// FAL fields are required for compliance — see [[Features/REGA Compliance]].
model agent_profiles {
  id                String                    @id @default(uuid())
  userId            String                    @unique
  organizationId    String?
  licenseNo         String                    @unique
  licenseValidTo    DateTime
  territories       String
  isIndividualAgent Boolean                   @default(false)
  status            AgentStatus               @default(PENDING_VERIFICATION)
  specialties       String
  experience        Int?
  bio               String?
  avatar            String?
  // ── FAL License (REGA) ──
  falLicenseNumber  String? // رقم رخصة فال (10-digit)
  falLicenseType    FalLicenseType? // نوع الرخصة
  falIssuedAt       DateTime? // تاريخ الإصدار
  falExpiresAt      DateTime? // تاريخ الانتهاء
  falStatus         LicenseVerificationStatus @default(PENDING)
  nationalIdNumber  String? // رقم الهوية الوطنية / الإقامة
  sreiCertified     Boolean                   @default(false) // اجتياز تدريب المعهد العقاري
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  organizations     organizations?            @relation(fields: [organizationId], references: [id])
  users             users                     @relation(fields: [userId], references: [id])

  @@index([licenseNo])
  @@index([falLicenseNumber])
  @@index([organizationId])
  @@index([status])
  @@index([userId])
}

/// Immutable append-only log of every meaningful mutation. Used for REGA audits and
/// for the per-record activity timeline. Stores before/after JSON snapshots.
model audit_logs {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entity     String
  entityId   String
  beforeJson String?
  afterJson  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  users      users    @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@index([entityId])
  @@index([entity])
  @@index([userId])
}

/// Buyer-side entries in the shared Pool (الطلبات العقارية).
/// Any agent can claim them via `claims`. Contact details are masked until claim.
model buyer_requests {
  id                 String             @id @default(uuid())
  createdByUserId    String
  city               String
  type               String
  minBedrooms        Int?
  maxBedrooms        Int?
  minPrice           Decimal?
  maxPrice           Decimal?
  contactPreferences String
  status             BuyerRequestStatus @default(OPEN)
  maskedContact      String
  fullContactJson    String
  multiAgentAllowed  Boolean            @default(false)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  users              users              @relation(fields: [createdByUserId], references: [id])
  claims             claims[]
  leads              leads[]

  @@index([city])
  @@index([createdByUserId])
  @@index([maxPrice])
  @@index([status])
  @@index([type])
}

/// Saudi cities, FK to regions. Used by listing/customer location pickers.
model cities {
  id              Int         @id
  regionId        Int
  nameAr          String
  nameEn          String
  centerLatitude  Decimal?
  centerLongitude Decimal?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  regions         regions     @relation(fields: [regionId], references: [id])
  districts       districts[]

  @@index([nameAr])
  @@index([nameEn])
  @@index([regionId])
}

/// An agent reserving a buyer request from the Pool. Active for 7 days (`expiresAt`).
/// While active, only the claiming agent sees full contact details.
model claims {
  id             String         @id @default(uuid())
  agentId        String
  buyerRequestId String
  claimedAt      DateTime       @default(now())
  expiresAt      DateTime
  status         ClaimStatus    @default(ACTIVE)
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  users          users          @relation(fields: [agentId], references: [id])
  buyer_requests buyer_requests @relation(fields: [buyerRequestId], references: [id])

  @@index([agentId])
  @@index([buyerRequestId])
  @@index([expiresAt])
  @@index([status])
}

/// Append-only log of every touchpoint with a lead — calls, WhatsApps, emails, in-person.
/// Used to compute `lastContactAt` on the parent lead and to power activity timelines.
model contact_logs {
  id          String         @id @default(uuid())
  leadId      String
  agentId     String
  note        String
  channel     ContactChannel
  contactedAt DateTime       @default(now())
  createdAt   DateTime       @default(now())
  users       users          @relation(fields: [agentId], references: [id])
  leads       leads          @relation(fields: [leadId], references: [id])

  @@index([agentId])
  @@index([contactedAt])
  @@index([leadId])
}

/// Saudi districts (الأحياء) within cities. Seeded with official boundary polygons (GeoJSON).
model districts {
  id        BigInt   @id
  regionId  Int
  cityId    Int
  nameAr    String
  nameEn    String
  boundary  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cities    cities   @relation(fields: [cityId], references: [id])
  regions   regions  @relation(fields: [regionId], references: [id])

  @@index([cityId])
  @@index([nameAr])
  @@index([nameEn])
  @@index([regionId])
}

/// A Lead is the *opportunity* wrapping a customer + intent (buy / rent / sell).
/// Distinct from `customers` which is the master record.
/// Lifecycle: NEW → IN_PROGRESS → WON / LOST. Once WON, a `deals` row is created.
/// Org-scoped via `organizationId`. See [[Features/CRM Core]].
model leads {
  id                 String              @id @default(uuid())
  agentId            String
  organizationId     String?
  customerId         String?
  buyerRequestId     String?
  sellerSubmissionId String?
  status             LeadStatus          @default(NEW)
  notes              String?
  source             String?
  priority           Int?
  assignedAt         DateTime?
  lastContactAt      DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  contact_logs       contact_logs[]
  users              users               @relation(fields: [agentId], references: [id])
  organization       organizations?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  customer           customers?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  buyer_requests     buyer_requests?     @relation(fields: [buyerRequestId], references: [id])
  seller_submissions seller_submissions? @relation(fields: [sellerSubmissionId], references: [id])

  @@index([agentId])
  @@index([organizationId])
  @@index([customerId])
  @@index([buyerRequestId])
  @@index([sellerSubmissionId])
  @@index([status])
}

/// A specific publication of a property to the market — for SALE or RENT.
/// REGA-compliant: must carry `regaAdLicenseNumber` + `falLicenseNumber` to publish.
/// Status lifecycle: DRAFT → PENDING_APPROVAL → ACTIVE → SOLD/RENTED.
model listings {
  id                  String               @id @default(uuid())
  propertyId          String
  agentId             String
  organizationId      String?
  unitId              String?
  sellerCustomerId    String?
  listingType         ListingType
  exclusive           Boolean              @default(false)
  publishedAt         DateTime?
  status              ListingStatus        @default(ACTIVE)
  price               Decimal?
  description         String?
  // ── REGA Advertising Compliance ──
  regaAdLicenseNumber String? // رقم ترخيص الإعلان العقاري
  falLicenseNumber    String? // رقم رخصة فال المستخدمة
  adStartDate         DateTime? // تاريخ بداية الإعلان
  adEndDate           DateTime? // تاريخ انتهاء الإعلان
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               users                @relation(fields: [agentId], references: [id])
  organizations       organizations?       @relation(fields: [organizationId], references: [id])
  properties          properties           @relation(fields: [propertyId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "listings_propertyid_fkey")
  seller              customers?           @relation("listing_seller", fields: [sellerCustomerId], references: [id], onDelete: SetNull)
  inquiries           inquiries[]
  appointments        appointments[]
  deals               deals[]
  promotions          listing_promotions[]

  @@index([agentId])
  @@index([listingType])
  @@index([organizationId])
  @@index([propertyId])
  @@index([unitId])
  @@index([sellerCustomerId])
  @@index([status])
}

/// Tenancy / agency / brokerage. The org-isolation key for the entire app.
/// Every multi-tenant table carries `organizationId` and is scoped via
/// `injectOrgFilter` middleware — see [[Architecture/Org Isolation]].
model organizations {
  id                          String                     @id @default(uuid())
  legalName                   String
  tradeName                   String
  licenseNo                   String                     @unique
  status                      OrganizationStatus         @default(PENDING_VERIFICATION)
  address                     String?
  phone                       String?
  email                       String?
  website                     String?
  industry                    String?
  size                        Int?
  countryCode                 String?
  city                        String?
  region                      String?
  timezone                    String?
  billingEmail                String?
  billingPhone                String?
  metadata                    Json?
  primaryContactId            String?
  // ── FAL License (REGA) ──
  falLicenseNumber            String? // رقم رخصة فال المنشأة
  falLicenseType              FalLicenseType?
  falIssuedAt                 DateTime?
  falExpiresAt                DateTime?
  falStatus                   LicenseVerificationStatus  @default(PENDING)
  crNumber                    String? // رقم السجل التجاري
  vatNumber                   String? // رقم التسجيل الضريبي
  // ── National Address (العنوان الوطني) ──
  nationalAddressBuildingNo   String? // رقم المبنى (4-digit)
  nationalAddressStreet       String? // اسم الشارع
  nationalAddressPostalCode   String? // الرمز البريدي (5-digit)
  nationalAddressAdditionalNo String? // الرقم الإضافي (4-digit)
  nationalAddressShortCode    String? // العنوان المختصر
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt
  agent_profiles              agent_profiles[]
  listings                    listings[]
  users                       users[]
  primaryContact              users?                     @relation("organization_primary_contact", fields: [primaryContactId], references: [id])
  memberships                 organization_memberships[]
  billing_accounts            billing_accounts[]
  settings                    organization_settings?
  analytics_event_logs        analytics_event_logs[]
  leads                       leads[]
  customers                   customers[]
  inquiries                   inquiries[]
  appointments                appointments[]
  deals                       deals[]
  support_tickets             support_tickets[]
  broker_requests             broker_requests[]
  campaigns                   campaigns[]                @relation("CampaignOrg")
  leadRoutingRule             lead_routing_rules?

  @@index([industry])
  @@index([licenseNo])
  @@index([primaryContactId])
  @@index([status])
}

/// Feature line items for a pricing plan (the bullets shown on the pricing page).
model pricing_plan_features {
  id            String        @id @default(uuid())
  text          String
  included      Boolean       @default(true)
  order         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  pricingPlanId String
  pricing_plans pricing_plans @relation(fields: [pricingPlanId], references: [id], onDelete: Cascade)
}

/// Subscription plan catalog — name, price, billing interval, currency (SAR by default).
model pricing_plans {
  id                    String                  @id @default(uuid())
  name                  String
  price                 Float
  period                String                  @default("monthly")
  billingInterval       String                  @default("monthly")
  currency              String                  @default("SAR")
  isPopular             Boolean                 @default(false)
  isArchived            Boolean                 @default(false)
  description           String
  buttonText            String                  @default("ابدأ الآن")
  order                 Int                     @default(0)
  metadata              Json?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  pricing_plan_features pricing_plan_features[]
  subscriptions         billing_subscriptions[]
}

/// Master property record — physical real estate the agency knows about.
/// Distinct from `listings` (a property can be unlisted, listed multiple times, etc.).
/// REGA fields: building age, facade direction, deed number, legal status.
/// See [[Features/Properties & Listings]].
model properties {
  id                          String               @id @default(uuid())
  agentId                     String?
  organizationId              String?
  title                       String?
  description                 String?
  type                        String?
  category                    String?
  city                        String?
  district                    String?
  address                     String?
  bedrooms                    Int?
  bathrooms                   Decimal?
  areaSqm                     Decimal?
  price                       Decimal?
  status                      PropertyStatus?
  visibility                  String?
  latitude                    Decimal?
  longitude                   Decimal?
  features                    String?
  photos                      String?
  // ── REGA Compliance Fields ──
  buildingAge                 Int? // عمر المبنى (بالسنوات)
  facadeDirection             String? // واجهة العقار (NORTH, SOUTH, etc.)
  availableServices           String? // الخدمات المتوفرة (JSON: electricity, water, sewage)
  legalStatus                 PropertyLegalStatus? // الحالة القانونية
  deedNumber                  String? // رقم الصك
  nationalAddressBuildingNo   String?
  nationalAddressPostalCode   String?
  nationalAddressAdditionalNo String?
  createdAt                   DateTime?            @default(now())
  updatedAt                   DateTime?            @updatedAt
  cityId                      Int?
  districtId                  BigInt?
  regionId                    Int?
  listings                    listings[]
  inquiries                   inquiries[]
  appointments                appointments[]
  deals                       deals[]
  agent                       users?               @relation("PropertyAgent", fields: [agentId], references: [id], onDelete: SetNull)
  favorites                   favorites[]
  broker_requests             broker_requests[]
  tenancies                   tenancies[]
  clientOffers                client_offers[]

  @@index([agentId])
  @@index([organizationId])
  @@index([status])
  @@index([city])
  @@index([cityId])
  @@index([district])
  @@index([status, city])
  @@index([status, city, type])
  @@index([createdAt])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.

/// Public buyer-side seeker entries from the landing page form.
/// Imported into `buyer_requests` once an agent claims them.
model properties_seeker {
  seeker_num             BigInt   @id @default(autoincrement())
  first_name             String
  last_name              String
  mobile_number          String
  email                  String
  nationality            String
  age                    Int
  monthly_income         Decimal
  gender                 String
  type_of_property       String
  type_of_contract       String
  number_of_rooms        Int
  number_of_bathrooms    Int
  number_of_living_rooms Int
  house_direction        String?
  budget_size            Decimal
  has_maid_room          Boolean  @default(false)
  has_driver_room        Boolean? @default(false)
  kitchen_installed      Boolean? @default(false)
  has_elevator           Boolean? @default(false)
  parking_available      Boolean? @default(false)
  city                   String?
  district               String?
  region                 String?
  other_comments         String?
  created_at             DateTime @default(now())
  updated_at             DateTime @default(now())
  Sqm                    BigInt?
  seeker_id              String?  @unique @default(dbgenerated("('S-'::text || lpad((seeker_num)::text, 11, '0'::text))")) @db.Char(13)

  @@unique([email, mobile_number])
  @@index([city, district])
  @@index([city])
  @@index([region])
  @@index([type_of_property, type_of_contract])
}

/// Saudi Arabia administrative regions (13 total). Seeded from official GASTAT data.
model regions {
  id              Int         @id
  code            String?
  nameAr          String
  nameEn          String
  population      Int?
  centerLatitude  Decimal?
  centerLongitude Decimal?
  boundary        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  cities          cities[]
  districts       districts[]

  @@index([nameAr])
  @@index([nameEn])
}

/// Seller-side entries in the shared Pool — owners looking for an agent to sell their property.
/// Mirror of `buyer_requests` for the opposite side of the marketplace.
model seller_submissions {
  id                  String                 @id @default(uuid())
  createdByUserId     String
  city                String
  type                String
  bedrooms            Int?
  priceExpectation    Decimal?
  exclusivePreference Boolean                @default(false)
  status              SellerSubmissionStatus @default(OPEN)
  maskedContact       String
  fullContactJson     String
  notes               String?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  leads               leads[]
  users               users                  @relation(fields: [createdByUserId], references: [id])

  @@index([city])
  @@index([createdByUserId])
  @@index([status])
  @@index([type])
}

/// Master record for a person — buyer, seller, or both.
/// Phone is unique within an organization (enforced at zod layer, not DB).
/// Linked to leads, inquiries, appointments, deals, listings (as seller), and tenancies.
model customers {
  id                String            @id @default(uuid())
  organizationId    String
  type              CustomerType      @default(BUYER)
  salutation        String?
  firstName         String
  lastName          String
  email             String?
  phone             String
  secondaryPhone    String?
  whatsappNumber    String?
  // TODO: Add application-level Zod validation for email format, phone format, mobile format
  preferredLanguage String?           @default("ar")
  city              String?
  district          String?
  nationality       String?
  source            String?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organization      organizations     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads             leads[]
  inquiries         inquiries[]
  appointments      appointments[]
  deals             deals[]
  support_tickets   support_tickets[]
  listings          listings[]        @relation("listing_seller")
  tenancies         tenancies[]

  @@index([organizationId])
  @@index([phone])
  @@index([email])
  @@index([city])
}

/// Inbound interest in a specific listing or property. Created by website forms,
/// WhatsApp webhooks, walk-ins, or referrals. Often the first step before a `lead` is created.
model inquiries {
  id             String         @id @default(uuid())
  organizationId String
  customerId     String
  propertyId     String?
  listingId      String?
  agentId        String?
  channel        InquiryChannel @default(WEBSITE)
  status         InquiryStatus  @default(NEW)
  message        String?
  preferredTime  DateTime?
  createdAt      DateTime       @default(now())
  respondedAt    DateTime?
  organization   organizations  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       customers      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property       properties?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  listing        listings?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  agent          users?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  appointments   appointments[]

  @@index([organizationId])
  @@index([customerId])
  @@index([propertyId])
  @@index([listingId])
  @@index([agentId])
  @@index([status])
}

/// Scheduled meetings — viewings, signings, follow-ups. Linked to a customer + optional
/// property/listing/inquiry. Powers the calendar page.
model appointments {
  id             String            @id @default(uuid())
  organizationId String
  customerId     String
  propertyId     String?
  listingId      String?
  inquiryId      String?
  agentId        String?
  status         AppointmentStatus @default(SCHEDULED)
  scheduledAt    DateTime
  /// Duration in minutes. Default 30. Used by conflict detection and calendar rendering.
  duration       Int               @default(30)
  location       String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   organizations     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer       customers         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  property       properties?       @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  listing        listings?         @relation(fields: [listingId], references: [id], onDelete: SetNull)
  inquiry        inquiries?        @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  agent          users?            @relation(fields: [agentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([customerId])
  @@index([propertyId])
  @@index([listingId])
  @@index([inquiryId])
  @@index([agentId])
  @@index([status])
  @@index([scheduledAt])
}

/// A deal is the post-qualification, pre-close opportunity. Drives the Kanban pipeline.
/// Stage transitions are tracked via `stageEnteredAt` (set on every stage change in
/// `apps/api/routes/deals.ts`) and powers the stuck-deal alerts on the dashboard.
/// Saudi compliance: commission ≤ 2.5%, RETT 5%, optional Ejar contract reference.
/// See [[Features/Pipeline & Deals]].
model deals {
  id                   String              @id @default(uuid())
  organizationId       String
  listingId            String?
  propertyId           String?
  customerId           String
  agentId              String?
  stage                DealStage           @default(NEW)
  source               String?
  expectedCloseDate    DateTime?
  agreedPrice          Decimal?            @db.Decimal(14, 2)
  currency             String              @default("SAR")
  wonAt                DateTime?
  lostAt               DateTime?
  stageEnteredAt       DateTime?           @default(now())
  notes                String?
  // ── Saudi Regulation: Commission, RETT, Ejar ──
  commissionPercentage Decimal?            @db.Decimal(5, 2) // نسبة العمولة (max 2.5% by law)
  commissionAmount     Decimal?            @db.Decimal(14, 2) // مبلغ العمولة
  rettAmount           Decimal?            @db.Decimal(14, 2) // ضريبة التصرفات العقارية (5%)
  rettPaidDate         DateTime? // تاريخ سداد الضريبة
  rettReference        String? // رقم مرجع هيئة الزكاة (ZATCA)
  firstHomeExemption   Boolean             @default(false) // إعفاء المسكن الأول (سكني)
  ejarContractNumber   String? // رقم عقد إيجار
  ejarRegistrationDate DateTime? // تاريخ تسجيل عقد إيجار
  brokerageContractRef String? // مرجع عقد الوساطة
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  organization         organizations       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  listing              listings?           @relation(fields: [listingId], references: [id], onDelete: SetNull)
  property             properties?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  customer             customers           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  agent                users?              @relation(fields: [agentId], references: [id], onDelete: SetNull)
  commissionSplits     commission_splits[]
  documents            deal_documents[]
  stageHistory         deal_stage_history[]

  @@index([organizationId])
  @@index([customerId])
  @@index([propertyId])
  @@index([listingId])
  @@index([agentId])
  @@index([stage])
}

/// Customer support tickets — opened by users, assigned to support staff.
model support_tickets {
  id               String                @id @default(uuid())
  organizationId   String
  customerId       String?
  createdByUserId  String?
  assignedToUserId String?
  subject          String
  description      String?
  status           SupportTicketStatus   @default(OPEN)
  priority         SupportTicketPriority @default(MEDIUM)
  channel          InquiryChannel?       @default(WEBSITE)
  categoryId       String?
  openedAt         DateTime              @default(now())
  closedAt         DateTime?
  updatedAt        DateTime              @updatedAt
  organization     organizations         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer         customers?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  category         support_categories?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy        users?                @relation("SupportTicketsCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)
  assignedTo       users?                @relation("SupportTicketsAssigned", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([customerId])
  @@index([assignedToUserId])
  @@index([status])
  @@index([priority])
  @@index([categoryId])
}

/// Categories for grouping support tickets in the admin queue.
model support_categories {
  id           String            @id @default(uuid())
  name         String
  description  String?
  slug         String            @unique
  displayOrder Int               @default(0)
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tickets      support_tickets[]

  @@index([slug])
  @@index([isActive])
}

/// Saved canned responses for support agents.
model support_templates {
  id         String   @id @default(uuid())
  title      String
  content    String   @db.Text
  usageCount Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // TODO: Review if this model needs relations or should be removed
  @@index([title])
}

/// Master user account — agents, admins, customers, owners.
/// All authentication and authorization flows hang off this table.
/// Roles are stored as a comma-separated string in `roles` and joined out via `user_roles`.
/// See [[Architecture/Authentication & RBAC]] in the vault.
model users {
  id                       String                     @id @default(uuid())
  username                 String                     @unique
  email                    String?                    @unique
  phone                    String?                    @unique
  firstName                String
  lastName                 String
  passwordHash             String
  roles                    String
  organizationId           String?
  isActive                 Boolean                    @default(true)
  lastLoginAt              DateTime?
  lastSeenAt               DateTime?
  jobTitle                 String?
  department               String?
  approvalStatus           UserApprovalStatus         @default(PENDING)
  timezone                 String?
  avatarUrl                String?
  metadata                 Json?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  agent_profiles           agent_profiles?
  audit_logs               audit_logs[]
  buyer_requests           buyer_requests[]
  claims                   claims[]
  contact_logs             contact_logs[]
  leads                    leads[]
  listings                 listings[]
  seller_submissions       seller_submissions[]
  organization             organizations?             @relation(fields: [organizationId], references: [id])
  organization_memberships organization_memberships[]
  user_roles               user_roles[]
  billing_accounts         billing_accounts[]
  primaryContactFor        organizations[]            @relation("organization_primary_contact")
  analytics_event_logs     analytics_event_logs[]
  supportTicketsCreated    support_tickets[]          @relation("SupportTicketsCreated")
  supportTicketsAssigned   support_tickets[]          @relation("SupportTicketsAssigned")
  inquiries                inquiries[]
  appointments             appointments[]
  deals                    deals[]
  community_posts          community_posts[]
  community_comments       community_comments[]
  forum_channels           forum_channels[]
  agentProperties          properties[]               @relation("PropertyAgent")
  saved_searches           saved_searches[]
  favorites                favorites[]
  content_reports          content_reports[]
  marketingRequests        marketing_requests[]       @relation("MarketingRequestOwner")
  marketingProposals       marketing_proposals[]      @relation("MarketingProposalAgent")
  brokerRequestsOwned      broker_requests[]          @relation("BrokerRequestOwner")
  brokerAcceptances        broker_acceptances[]       @relation("BrokerAcceptanceAgent")
  campaigns                campaigns[]                @relation("CampaignAgent")
  automationRules          automation_rules[]         @relation("AutomationAgent")
  listingPromotions        listing_promotions[]       @relation("PromotionAgent")
  commissionSplits         commission_splits[]        @relation("CommissionRecipient")
  tenancies                tenancies[]                @relation("TenancyAgent")
  sequences                campaign_sequences[]       @relation("SequenceAgent")
  uploadedDocuments        deal_documents[]           @relation("DocumentUploader")
  clientOffers             client_offers[]            @relation("BuyerOffers")

  @@index([approvalStatus])
  @@index([email])
  @@index([isActive])
  @@index([organizationId])
}

