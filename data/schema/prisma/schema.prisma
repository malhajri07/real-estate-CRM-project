/// GASTAT-aligned top-level property categories (5 total): Residential, Commercial,
/// Industrial, Agricultural, Land. See [[Features/REGA Compliance]].
model property_category {
  id            Int      @id @default(autoincrement())
  code          String   @unique @db.VarChar(20)
  name_ar       String   @db.VarChar(100)
  name_en       String?  @db.VarChar(100)
  description   String?  @db.Text
  icon          String?  @db.VarChar(100)
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  property_types property_type[]

  @@index([code])
  @@index([is_active])
  @@map("property_category")
}

/// GASTAT-aligned property types (33 total) within each category.
/// Drives the property creation form's category → type cascade.
model property_type {
  id            Int      @id @default(autoincrement())
  category_id   Int
  code          String   @db.VarChar(50)
  name_ar       String   @db.VarChar(100)
  name_en       String?  @db.VarChar(100)
  description   String?  @db.Text
  icon          String?  @db.VarChar(100)
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  category property_category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, code])
  @@index([category_id])
  @@index([is_active])
  @@index([code])
  @@map("property_type")
}

/// Topical forum channels (e.g. عام, سوق, قانوني, تقنية).
model forum_channels {
  id          String            @id @default(uuid())
  nameAr      String            @db.VarChar(100)
  nameEn      String?           @db.VarChar(100)
  description String?           @db.Text
  createdById String
  isPublic    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   users             @relation(fields: [createdById], references: [id], onDelete: Cascade)
  posts       community_posts[]

  @@index([createdById])
  @@index([isPublic])
}

/// Forum posts. Has likes, pinning, type tag (DISCUSSION/NEWS/ANNOUNCEMENT/DEAL/ALERT).
model community_posts {
  id        String                 @id @default(uuid())
  authorId  String
  channelId String?
  content   String                 @db.Text
  tags      Json? // Array of strings e.g. ["Riyadh", "Villa"]
  likes     Int                    @default(0)
  isPinned  Boolean                @default(false)
  type      String                 @default("DISCUSSION") // DISCUSSION, NEWS, ANNOUNCEMENT, DEAL, ALERT
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  author    users                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  channel   forum_channels?        @relation(fields: [channelId], references: [id], onDelete: SetNull)
  comments  community_comments[]
  media     community_post_media[]

  @@index([authorId])
  @@index([channelId])
  @@index([type])
  @@index([createdAt])
}

/// Media attachments (image / video) for a community post.
model community_post_media {
  id        String          @id @default(uuid())
  postId    String
  url       String          @db.Text
  type      String          @db.VarChar(20) // IMAGE, VIDEO
  order     Int             @default(0)
  createdAt DateTime        @default(now())
  post      community_posts @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

/// Comments on community posts.
model community_comments {
  id        String          @id @default(uuid())
  postId    String
  authorId  String
  content   String          @db.Text
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  post      community_posts @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    users           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

/// Per-agent notes / reminders. Lightweight memory store for agent-specific facts.
model agent_memory {
  id             String   @id @default(uuid())
  agentId        String
  conversationId String?
  type           String
  status         String
  summary        String   @db.Text
  details        Json?
  tags           String[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // TODO: Review if this model needs relations or should be removed
  @@index([type])
  @@index([createdAt])
}

/// Customer-saved search criteria with frequency-based alerting.
model saved_searches {
  id            String   @id @default(uuid())
  customerId    String
  alertName     String
  propertyTypes String[]
  cities        String[]
  minPrice      Decimal? @db.Decimal(14, 2)
  maxPrice      Decimal? @db.Decimal(14, 2)
  minBedrooms   Int?
  maxBedrooms   Int?
  frequency     String?  @default("daily")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          users    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([isActive])
}

/// Customer's saved properties on the public site / client portal.
model favorites {
  id         String     @id @default(uuid())
  userId     String
  propertyId String
  createdAt  DateTime   @default(now())
  user       users      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

/// User-submitted reports of inappropriate listings. Drives the moderation queue.
model content_reports {
  id         String   @id @default(uuid())
  listingId  String
  reporterId String?
  reason     String
  status     String   @default("PENDING")
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  reporter   users?   @relation(fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([reporterId])
  @@index([status])
}

/// Generic marketing-help requests posted by property owners. Agents respond with
/// `marketing_proposals`. The owner picks the winning proposal.
model marketing_requests {
  id                    String                @id @default(uuid())
  ownerId               String
  title                 String
  summary               String                @db.Text
  requirements          String?               @db.Text
  propertyType          String
  listingType           String?
  city                  String
  district              String?
  region                String?
  budgetMin             Decimal?              @db.Decimal(14, 2)
  budgetMax             Decimal?              @db.Decimal(14, 2)
  preferredStartDate    DateTime?
  preferredEndDate      DateTime?
  commissionExpectation Decimal?              @db.Decimal(9, 4)
  seriousnessTier       String                @default("STANDARD")
  contactName           String
  contactPhone          String?
  contactEmail          String?
  propertyId            String?
  status                String                @default("DRAFT")
  moderationNotes       String?               @db.Text
  approvedAt            DateTime?
  closedAt              DateTime?
  awardedProposalId     String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  owner                 users                 @relation("MarketingRequestOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  proposals             marketing_proposals[]

  @@index([ownerId])
  @@index([status])
  @@index([city])
  @@index([seriousnessTier])
}

/// Agent proposal in response to a marketing_request — message, commission rate,
/// marketing budget, estimated timeline.
model marketing_proposals {
  id                String             @id @default(uuid())
  requestId         String
  agentId           String
  message           String?            @db.Text
  commissionRate    Decimal?           @db.Decimal(9, 4)
  marketingBudget   Decimal?           @db.Decimal(14, 2)
  estimatedTimeline String?
  attachments       String?            @db.Text
  status            String             @default("PENDING")
  decidedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  request           marketing_requests @relation(fields: [requestId], references: [id], onDelete: Cascade)
  agent             users              @relation("MarketingProposalAgent", fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([requestId, agentId])
  @@index([requestId])
  @@index([agentId])
  @@index([status])
}

// ── Broker Collaboration Requests ──────────────────────────────────────────
// Agents post their listings for co-marketing. Other agents accept and market
// the property in exchange for an agreed commission split.

/// Co-marketing broker request lifecycle.
enum BrokerRequestStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

/// Co-marketing offers — an agent posts their listing for other agents to help market
/// in exchange for a commission split. Capped by REGA commission rules.
model broker_requests {
  id                     String              @id @default(uuid())
  listingAgentId         String // Agent who owns the listing
  organizationId         String?
  propertyId             String? // Optional link to property
  listingId              String? // Optional link to listing
  title                  String // e.g. "فيلا VIP في الرياض — عمولة 2%"
  description            String?             @db.Text // Details about the deal
  propertyType           String? // villa, apartment, land, etc.
  city                   String?
  district               String?
  price                  Decimal?            @db.Decimal(14, 2) // Property asking price
  commissionRate         Decimal             @db.Decimal(5, 2) // e.g. 2.50 = 2.5%
  commissionType         String              @default("PERCENTAGE") // PERCENTAGE or FIXED
  fixedCommission        Decimal?            @db.Decimal(14, 2) // Flat amount if commissionType=FIXED
  status                 BrokerRequestStatus @default(OPEN)
  commissionCapValidated Boolean             @default(false) // تم التحقق من سقف العمولة النظامي
  expiresAt              DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  listingAgent users                @relation("BrokerRequestOwner", fields: [listingAgentId], references: [id])
  organization organizations?       @relation(fields: [organizationId], references: [id])
  property     properties?          @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  acceptances  broker_acceptances[]

  @@index([listingAgentId])
  @@index([organizationId])
  @@index([status])
  @@index([city])
  @@index([createdAt])
}

/// Agent acceptance of a broker_request. Carries the negotiated rate and the
/// co-brokerage agreement signing state (DRAFT → PENDING_SIGNATURES → SIGNED).
model broker_acceptances {
  id                     String    @id @default(uuid())
  brokerRequestId        String
  marketingAgentId       String // Agent who accepted to market
  organizationId         String?
  status                 String    @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  notes                  String?   @db.Text
  agreedRate             Decimal?  @db.Decimal(5, 2) // May differ from original offer after negotiation
  // ── Co-Brokerage Agreement ──
  agreementStatus        String? // DRAFT, PENDING_SIGNATURES, SIGNED, EXPIRED
  agreementNumber        String? // CBA-YYYY-XXXXX
  agreementTerms         String?   @db.Text // JSON: property, agents, commission, terms
  agreementGeneratedAt   DateTime?
  listingAgentSignedAt   DateTime?
  marketingAgentSignedAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  brokerRequest  broker_requests @relation(fields: [brokerRequestId], references: [id], onDelete: Cascade)
  marketingAgent users           @relation("BrokerAcceptanceAgent", fields: [marketingAgentId], references: [id])

  @@unique([brokerRequestId, marketingAgentId])
  @@index([brokerRequestId])
  @@index([marketingAgentId])
  @@index([status])
  @@index([agreementStatus])
}

// ── Campaign Management ────────────────────────────────────────────────────────

/// Bulk WhatsApp / SMS / email blast to a segment of leads or customers.
/// Counters track delivered/opened/responded for performance reporting.
model campaigns {
  id             String         @id @default(uuid())
  agentId        String
  organizationId String?
  title          String
  message        String         @db.Text
  channel        String // whatsapp, sms, email
  status         CampaignStatus @default(SENT)
  recipientCount Int            @default(0)
  deliveredCount Int            @default(0)
  openedCount    Int            @default(0)
  respondedCount Int            @default(0)
  templateId     String?
  segmentFilter  String?        @db.Text // JSON: filter criteria used
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  agent        users                 @relation("CampaignAgent", fields: [agentId], references: [id])
  organization organizations?        @relation("CampaignOrg", fields: [organizationId], references: [id], onDelete: SetNull)
  recipients   campaign_recipients[]

  @@index([agentId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

/// Per-recipient state for a campaign. One row per (campaign, recipient).
model campaign_recipients {
  id          String                  @id @default(uuid())
  campaignId  String
  leadId      String?
  customerId  String?
  name        String?
  phone       String?
  email       String?
  status      CampaignRecipientStatus @default(PENDING)
  deliveredAt DateTime?
  openedAt    DateTime?
  respondedAt DateTime?
  createdAt   DateTime                @default(now())

  campaign campaigns @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([leadId])
  @@index([status])
}

/// Trigger → action rules for hands-off agent workflows.
/// Triggers: new_lead, cold_lead, listing_match, appointment_reminder, price_drop, deal_stale.
model automation_rules {
  id              String    @id @default(uuid())
  agentId         String
  organizationId  String?
  name            String
  description     String?
  triggerType     String // new_lead, cold_lead, listing_match, appointment_reminder, price_drop, deal_stale
  triggerConfig   String?   @db.Text // JSON: threshold days, conditions
  actionType      String // send_whatsapp, send_sms, send_email, internal_notification
  actionConfig    String?   @db.Text // JSON: template, message
  channel         String // whatsapp, sms, email, internal
  enabled         Boolean   @default(true)
  lastTriggeredAt DateTime?
  triggerCount    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agent users @relation("AutomationAgent", fields: [agentId], references: [id])

  @@index([agentId])
  @@index([enabled])
  @@index([triggerType])
}

/// Bulk campaign send lifecycle.
enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  DELIVERING
  COMPLETED
  FAILED
  CANCELLED
}

/// Per-recipient delivery state.
enum CampaignRecipientStatus {
  PENDING
  DELIVERED
  OPENED
  RESPONDED
  FAILED
  BOUNCED
}

// ── Listing Promotions (Boost / Ads) ───────────────────────────────────────────

/// Paid boost / ad placement for a listing. Daily + total budget, bid amount,
/// targeting (cities, types, buyer budget). Auto-pause when spend ≥ 95%.
model listing_promotions {
  id              String          @id @default(uuid())
  listingId       String
  agentId         String
  organizationId  String?
  status          PromotionStatus @default(ACTIVE)
  dailyBudget     Decimal // ميزانية يومية
  totalBudget     Decimal? // ميزانية إجمالية (اختياري)
  spentAmount     Decimal         @default(0)
  bidAmount       Decimal // مبلغ المزايدة لكل ظهور
  targetCities    String? // JSON: المدن المستهدفة
  targetTypes     String? // JSON: أنواع العقارات المستهدفة
  targetBudgetMin Decimal? // الحد الأدنى لميزانية الباحث
  targetBudgetMax Decimal? // الحد الأقصى لميزانية الباحث
  impressions     Int             @default(0)
  clicks          Int             @default(0)
  inquiries       Int             @default(0)
  startDate       DateTime        @default(now())
  endDate         DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  listing listings @relation(fields: [listingId], references: [id], onDelete: Cascade)
  agent   users    @relation("PromotionAgent", fields: [agentId], references: [id])

  @@index([agentId])
  @@index([listingId])
  @@index([status])
  @@index([createdAt])
}

/// Listing promotion / boost lifecycle.
enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXHAUSTED // ميزانية مستنفدة
  ENDED
  CANCELLED
}

// ── Commission Splits ──────────────────────────────────────────────────────────

/// How a deal's commission is divided between agents, brokerages, and referrers.
/// Status tracks the payout lifecycle (PENDING → APPROVED → PAID).
model commission_splits {
  id            String           @id @default(uuid())
  dealId        String
  recipientId   String
  recipientType String // AGENT, BROKERAGE, REFERRAL
  percentage    Decimal          @db.Decimal(5, 2)
  amount        Decimal          @db.Decimal(14, 2)
  status        CommissionStatus @default(PENDING)
  paidAt        DateTime?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  deal      deals @relation(fields: [dealId], references: [id], onDelete: Cascade)
  recipient users @relation("CommissionRecipient", fields: [recipientId], references: [id])

  @@index([dealId])
  @@index([recipientId])
  @@index([status])
}

/// Commission split payout state.
enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

// ── Lead Routing ───────────────────────────────────────────────────────────────

/// How new leads are auto-assigned within an org.
/// Strategies: manual, round_robin, territory, first_to_claim.
model lead_routing_rules {
  id              String   @id @default(uuid())
  organizationId  String   @unique
  strategy        String   @default("manual") // round_robin, territory, manual, first_to_claim
  config          String?  @db.Text // JSON: { lastAssignedIndex, excludeInactive, maxLeadsPerAgent }
  enabled         Boolean  @default(true)
  lastAssignedIdx Int      @default(0) // For round-robin tracking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ── Tenant Management (Post-Rental Lifecycle) ──────────────────────────────────

/// Active rental contract — tenant, property, agent, monthly rent, lease window.
/// Created from a deal once stage = WON for a RENT listing.
/// Powers the tenant management page.
model tenancies {
  id              String        @id @default(uuid())
  dealId          String?
  propertyId      String
  tenantId        String // customerId
  agentId         String
  organizationId  String?
  leaseStart      DateTime
  leaseEnd        DateTime
  monthlyRent     Decimal       @db.Decimal(14, 2)
  securityDeposit Decimal?      @db.Decimal(14, 2)
  status          TenancyStatus @default(ACTIVE)
  ejarContractNo  String?
  notes           String?
  /// Last time a WhatsApp renewal reminder was sent to the tenant (E6).
  renewalReminderSentAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  property     properties      @relation(fields: [propertyId], references: [id])
  tenant       customers       @relation(fields: [tenantId], references: [id])
  agent        users           @relation("TenancyAgent", fields: [agentId], references: [id])
  rentPayments rent_payments[]

  @@index([agentId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([status])
  @@index([leaseEnd])
}

/// Scheduled rent payments for a tenancy. One row per due-date.
/// Status PENDING → PAID / OVERDUE / PARTIAL / WAIVED. Drives late-payment alerts.
model rent_payments {
  id        String            @id @default(uuid())
  tenancyId String
  amount    Decimal           @db.Decimal(14, 2)
  dueDate   DateTime
  paidDate  DateTime?
  status    RentPaymentStatus @default(PENDING)
  notes     String?
  createdAt DateTime          @default(now())

  tenancy tenancies @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@index([tenancyId])
  @@index([dueDate])
  @@index([status])
}

/// Active rental lifecycle. EXPIRING = within 90 days of leaseEnd.
enum TenancyStatus {
  ACTIVE
  EXPIRING // within 90 days of end
  EXPIRED
  RENEWED
  TERMINATED
}

/// Rent payment state — drives late-payment alerts.
enum RentPaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  WAIVED
}

// ── Drip Campaign Sequences ─────────────────────────────────────────────────────

/// Drip-campaign sequence definition — ordered steps with delays + templates.
/// Stored as JSON in `steps`.
model campaign_sequences {
  id        String   @id @default(uuid())
  agentId   String
  name      String
  channel   String   @default("whatsapp")
  steps     String   @db.Text // JSON array: [{delay: "0d", template: "welcome", message: "..."}, ...]
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent       users                  @relation("SequenceAgent", fields: [agentId], references: [id])
  enrollments sequence_enrollments[]

  @@index([agentId])
}

/// Active enrollment of a lead in a campaign_sequence. Tracks current step + next run time.
model sequence_enrollments {
  id          String    @id @default(uuid())
  sequenceId  String
  leadId      String
  currentStep Int       @default(0)
  nextRunAt   DateTime?
  status      String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED, CANCELLED
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sequence campaign_sequences @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([sequenceId])
  @@index([leadId])
  @@index([status])
  @@index([nextRunAt])
}

// ── Deal Documents ─────────────────────────────────────────────────────────────

/// Files attached to a deal — contracts, ID copies, brokerage agreements, payment receipts.
/// URL points to S3 / GCS storage; metadata only is stored in the DB.
model deal_documents {
  id         String   @id @default(uuid())
  dealId     String
  fileName   String
  fileUrl    String
  fileType   String? // pdf, image, doc
  fileSize   Int? // bytes
  uploadedBy String
  notes      String?
  createdAt  DateTime @default(now())

  deal     deals @relation(fields: [dealId], references: [id], onDelete: Cascade)
  uploader users @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([dealId])
  @@index([uploadedBy])
}

// ── Deal Stage History ─────────────────────────────────────────────────────────

/// Tracks every stage transition for a deal. Powers the visual deal progress tracker
/// in the client portal. Each row = one stage the deal entered, with timestamp.
model deal_stage_history {
  id        String   @id @default(uuid())
  dealId    String
  stage     String
  enteredAt DateTime @default(now())
  changedBy String?

  deal deals @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([enteredAt])
}

// ── Client Offers ──────────────────────────────────────────────────────────────

/// Buyer-submitted offers on properties. Visible to the listing agent for review.
/// Status: PENDING → ACCEPTED / REJECTED / EXPIRED / WITHDRAWN.
model client_offers {
  id           String   @id @default(uuid())
  propertyId   String
  buyerUserId  String
  offerPrice   Decimal  @db.Decimal(14, 2)
  conditions   String?
  message      String?
  status       String   @default("PENDING")
  agentNotes   String?
  respondedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  property properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  buyer    users      @relation("BuyerOffers", fields: [buyerUserId], references: [id])

  @@index([propertyId])
  @@index([buyerUserId])
  @@index([status])
}

// ── WhatsApp / Omnichannel Inbox Messages ──────────────────────────────────────

/// Two-way inbox — every WhatsApp/SMS/email message in or out of the system.
/// Inbound messages from the WhatsApp webhook are matched to a customer by phone.
model messages {
  id          String    @id @default(uuid())
  leadId      String?
  customerId  String?
  agentId     String
  direction   String // INBOUND, OUTBOUND
  channel     String // whatsapp, sms, email
  content     String    @db.Text
  phone       String?
  status      String    @default("SENT") // SENT, DELIVERED, READ, FAILED
  sentAt      DateTime  @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
  metadata    String?   @db.Text // JSON: whatsapp message id, etc.

  @@index([leadId])
  @@index([customerId])
  @@index([agentId])
  @@index([channel])
  @@index([sentAt])
}

// ── Off-Plan Projects ────────────────────────────────────────────────────────

/// Off-plan / under-construction projects (مشاريع تطويرية).
/// Status: PLANNING → UNDER_CONSTRUCTION → COMPLETED → ON_HOLD.
model projects {
  id             String    @id @default(uuid())
  name           String
  developer      String?
  city           String
  district       String?
  description    String?   @db.Text
  status         String    @default("PLANNING") // PLANNING, UNDER_CONSTRUCTION, COMPLETED, ON_HOLD
  completionDate DateTime?
  totalUnits     Int       @default(0)
  agentId        String
  organizationId String?
  coverImage     String?
  /// Construction completion percentage 0-100 (E18). Consumer: progress bar on project cards.
  constructionProgress Int    @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  units project_units[]

  @@index([agentId])
  @@index([organizationId])
  @@index([city])
  @@index([status])
}

/// Individual units (apartments, villas, townhouses) within a project.
/// Status: AVAILABLE → RESERVED → SOLD → BLOCKED. Has payment milestone schedule.
model project_units {
  id              String    @id @default(uuid())
  projectId       String
  unitNumber      String
  floor           Int?
  type            String? // apartment, villa, townhouse, etc.
  areaSqm         Decimal?  @db.Decimal(10, 2)
  bedrooms        Int?
  bathrooms       Int?
  price           Decimal?  @db.Decimal(14, 2)
  status          String    @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD, BLOCKED
  buyerName       String?
  buyerPhone      String?
  reservedAt      DateTime?
  paymentSchedule String?   @db.Text // JSON: [{milestone, percentage, amount, dueDate, paidDate}]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project projects @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

// ── Maintenance Request System (Session 5.6) ────────────────────────────────

/// Tenant-reported maintenance issues. Routed to vendors. Tracks status + cost.
model maintenance_requests {
  id             String    @id @default(uuid())
  tenancyId      String?
  propertyId     String
  reportedBy     String // userId or customerId
  category       String // plumbing, electrical, hvac, general, structural
  description    String    @db.Text
  photos         String?   @db.Text // JSON array of URLs
  priority       String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status         String    @default("SUBMITTED") // SUBMITTED, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  assignedVendor String?
  vendorNotes    String?
  completedAt    DateTime?
  cost           Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([propertyId])
  @@index([status])
  @@index([tenancyId])
}

// ── Vendor / Contractor Database (Session 5.7) ──────────────────────────────

/// Contractor / vendor directory — plumbing, electrical, HVAC, etc. Rated 1-5.
model vendors {
  id             String   @id @default(uuid())
  name           String
  phone          String
  email          String?
  specialization String // plumbing, electrical, hvac, cleaning, painting, general
  city           String?
  rating         Decimal? @db.Decimal(2, 1) // 1.0 - 5.0
  isActive       Boolean  @default(true)
  notes          String?
  agentId        String
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([agentId])
  @@index([organizationId])
  @@index([specialization])
}

// ── Viewing Feedback Forms (Session 5.8) ─────────────────────────────────────

/// Post-viewing feedback from customers. Ratings for location/condition/price/overall.
model viewing_feedback {
  id              String   @id @default(uuid())
  appointmentId   String   @unique
  customerId      String?
  locationRating  Int? // 1-5
  conditionRating Int? // 1-5
  priceRating     Int? // 1-5
  overallRating   Int? // 1-5
  comments        String?
  /// Agent rating from the customer (1-5 stars). Source: client portal "Rate Agent" (E15).
  agentRating     Int?
  /// Free-text agent review. Source: client portal rating form (E15).
  agentReviewText String?
  createdAt       DateTime @default(now())

  @@index([appointmentId])
  @@index([customerId])
}

// ── Land Subdivision ───────────────────────────────────────────────────────────

/// Land subdivision plans — splitting a large parcel into sellable lots (مخططات الأراضي).
model land_subdivisions {
  id               String   @id @default(uuid())
  parentPropertyId String
  agentId          String
  organizationId   String?
  totalArea        Decimal  @db.Decimal(14, 2)
  lotCount         Int      @default(0)
  status           String   @default("PLANNING") // PLANNING, APPROVED, IN_PROGRESS, COMPLETED
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lots subdivision_lots[]

  @@index([parentPropertyId])
  @@index([agentId])
}

/// Individual lots within a land_subdivision.
model subdivision_lots {
  id             String   @id @default(uuid())
  subdivisionId  String
  lotNumber      String
  areaSqm        Decimal  @db.Decimal(10, 2)
  price          Decimal? @db.Decimal(14, 2)
  status         String   @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD
  buyerName      String?
  buyerPhone     String?
  infrastructure String?  @db.Text // JSON: { water, electricity, sewage, road }
  createdAt      DateTime @default(now())

  subdivision land_subdivisions @relation(fields: [subdivisionId], references: [id], onDelete: Cascade)

  @@index([subdivisionId])
  @@index([status])
}

// ── Warranty Tracking ──────────────────────────────────────────────────────────

/// Tracked warranties on property components (AC, water heater, elevator) with expiry dates.
model property_warranties {
  id          String    @id @default(uuid())
  propertyId  String
  itemName    String // AC, water heater, elevator, etc.
  brand       String?
  installedAt DateTime?
  expiresAt   DateTime
  vendor      String?
  notes       String?
  createdAt   DateTime  @default(now())

  @@index([propertyId])
  @@index([expiresAt])
}

// ── Saved Filter Presets (E7) ─────────────────────────────────────────────────

/// Agent-saved filter presets for the properties list page (E7).
/// filterConfig is a JSON object storing the active filter state.
model saved_filters {
  id           String   @id @default(uuid())
  agentId      String
  name         String
  filterConfig String   @db.Text  // JSON: { city, type, listingType, minPrice, maxPrice, ... }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([agentId])
}

// ── Property Price History (E8) ───────────────────────────────────────────────

/// Tracks price changes on a property over time (E8).
/// One row per price modification. Source: listing update route.
/// Consumer: price timeline on property detail page.
model property_price_history {
  id         String   @id @default(uuid())
  propertyId String
  oldPrice   Decimal  @db.Decimal(14, 2)
  newPrice   Decimal  @db.Decimal(14, 2)
  changedAt  DateTime @default(now())
  changedBy  String?  // userId who made the change

  @@index([propertyId])
  @@index([changedAt])
}

// ── Conversation Labels (E12) ─────────────────────────────────────────────────

/// Agent-applied labels on inbox conversations (E12).
/// conversationKey is the leadId or phone that groups messages.
/// Consumer: label filter + badges in inbox page.
model conversation_labels {
  id              String   @id @default(uuid())
  conversationKey String   // leadId or phone number
  agentId         String
  label           String   // e.g. "عميل ساخن", "متابعة", "مكتمل"
  createdAt       DateTime @default(now())

  @@unique([conversationKey, agentId, label])
  @@index([agentId])
  @@index([conversationKey])
}

// ── Login History (E13) ───────────────────────────────────────────────────────

/// Tracks user login events with device + IP for the settings activity log (E13).
/// Consumer: "Activity Log" section in settings page.
model login_history {
  id        String   @id @default(uuid())
  userId    String
  loginAt   DateTime @default(now())
  ipAddress String?
  userAgent String?

  @@index([userId])
  @@index([loginAt])
}
