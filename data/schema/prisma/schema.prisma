  @@unique([requestId, agentId])
  @@index([requestId])
  @@index([agentId])
  @@index([status])
}

// ── Broker Collaboration Requests ──────────────────────────────────────────
// Agents post their listings for co-marketing. Other agents accept and market
// the property in exchange for an agreed commission split.

enum BrokerRequestStatus {
  OPEN
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

model broker_requests {
  id               String              @id @default(uuid())
  listingAgentId   String                                    // Agent who owns the listing
  organizationId   String?
  propertyId       String?                                   // Optional link to property
  listingId        String?                                   // Optional link to listing
  title            String                                    // e.g. "فيلا VIP في الرياض — عمولة 2%"
  description      String?             @db.Text              // Details about the deal
  propertyType     String?                                   // villa, apartment, land, etc.
  city             String?
  district         String?
  price            Decimal?            @db.Decimal(14, 2)    // Property asking price
  commissionRate   Decimal             @db.Decimal(5, 2)     // e.g. 2.50 = 2.5%
  commissionType   String              @default("PERCENTAGE") // PERCENTAGE or FIXED
  fixedCommission  Decimal?            @db.Decimal(14, 2)    // Flat amount if commissionType=FIXED
  status                BrokerRequestStatus @default(OPEN)
  commissionCapValidated Boolean           @default(false) // تم التحقق من سقف العمولة النظامي
  expiresAt             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  listingAgent     users               @relation("BrokerRequestOwner", fields: [listingAgentId], references: [id])
  organization     organizations?      @relation(fields: [organizationId], references: [id])
  property         properties?         @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  acceptances      broker_acceptances[]

  @@index([listingAgentId])
  @@index([organizationId])
  @@index([status])
  @@index([city])
  @@index([createdAt])
}

model broker_acceptances {
  id                      String              @id @default(uuid())
  brokerRequestId         String
  marketingAgentId        String                                    // Agent who accepted to market
  organizationId          String?
  status                  String              @default("PENDING")   // PENDING, APPROVED, REJECTED, COMPLETED
  notes                   String?             @db.Text
  agreedRate              Decimal?            @db.Decimal(5, 2)     // May differ from original offer after negotiation
  // ── Co-Brokerage Agreement ──
  agreementStatus         String?                                   // DRAFT, PENDING_SIGNATURES, SIGNED, EXPIRED
  agreementNumber         String?                                   // CBA-YYYY-XXXXX
  agreementTerms          String?             @db.Text              // JSON: property, agents, commission, terms
  agreementGeneratedAt    DateTime?
  listingAgentSignedAt    DateTime?
  marketingAgentSignedAt  DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  brokerRequest    broker_requests     @relation(fields: [brokerRequestId], references: [id], onDelete: Cascade)
  marketingAgent   users               @relation("BrokerAcceptanceAgent", fields: [marketingAgentId], references: [id])

  @@unique([brokerRequestId, marketingAgentId])
  @@index([brokerRequestId])
  @@index([marketingAgentId])
  @@index([status])
  @@index([agreementStatus])
}

// ── Campaign Management ────────────────────────────────────────────────────────

model campaigns {
  id              String               @id @default(uuid())
  agentId         String
  organizationId  String?
  title           String
  message         String               @db.Text
  channel         String               // whatsapp, sms, email
  status          CampaignStatus       @default(SENT)
  recipientCount  Int                  @default(0)
  deliveredCount  Int                  @default(0)
  openedCount     Int                  @default(0)
  respondedCount  Int                  @default(0)
  templateId      String?
  segmentFilter   String?              @db.Text  // JSON: filter criteria used
  scheduledAt     DateTime?
  sentAt          DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  agent           users                @relation("CampaignAgent", fields: [agentId], references: [id])
  organization    organizations?       @relation("CampaignOrg", fields: [organizationId], references: [id], onDelete: SetNull)
  recipients      campaign_recipients[]

  @@index([agentId])
  @@index([organizationId])
  @@index([status])
  @@index([createdAt])
}

model campaign_recipients {
  id           String              @id @default(uuid())
  campaignId   String
  leadId       String?
  customerId   String?
  name         String?
  phone        String?
  email        String?
  status       CampaignRecipientStatus @default(PENDING)
  deliveredAt  DateTime?
  openedAt     DateTime?
  respondedAt  DateTime?
  createdAt    DateTime            @default(now())

  campaign     campaigns           @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([leadId])
  @@index([status])
}

model automation_rules {
  id              String             @id @default(uuid())
  agentId         String
  organizationId  String?
  name            String
  description     String?
  triggerType     String             // new_lead, cold_lead, listing_match, appointment_reminder, price_drop, deal_stale
  triggerConfig   String?            @db.Text  // JSON: threshold days, conditions
  actionType      String             // send_whatsapp, send_sms, send_email, internal_notification
  actionConfig    String?            @db.Text  // JSON: template, message
  channel         String             // whatsapp, sms, email, internal
  enabled         Boolean            @default(true)
  lastTriggeredAt DateTime?
  triggerCount    Int                @default(0)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  agent           users              @relation("AutomationAgent", fields: [agentId], references: [id])

  @@index([agentId])
  @@index([enabled])
  @@index([triggerType])
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  DELIVERING
  COMPLETED
  FAILED
  CANCELLED
}

enum CampaignRecipientStatus {
  PENDING
  DELIVERED
  OPENED
  RESPONDED
  FAILED
  BOUNCED
}

// ── Listing Promotions (Boost / Ads) ───────────────────────────────────────────

model listing_promotions {
  id              String              @id @default(uuid())
  listingId       String
  agentId         String
  organizationId  String?
  status          PromotionStatus     @default(ACTIVE)
  dailyBudget     Decimal             // ميزانية يومية
  totalBudget     Decimal?            // ميزانية إجمالية (اختياري)
  spentAmount     Decimal             @default(0)
  bidAmount       Decimal             // مبلغ المزايدة لكل ظهور
  targetCities    String?             // JSON: المدن المستهدفة
  targetTypes     String?             // JSON: أنواع العقارات المستهدفة
  targetBudgetMin Decimal?            // الحد الأدنى لميزانية الباحث
  targetBudgetMax Decimal?            // الحد الأقصى لميزانية الباحث
  impressions     Int                 @default(0)
  clicks          Int                 @default(0)
  inquiries       Int                 @default(0)
  startDate       DateTime            @default(now())
  endDate         DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  listing         listings            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  agent           users               @relation("PromotionAgent", fields: [agentId], references: [id])

  @@index([agentId])
  @@index([listingId])
  @@index([status])
  @@index([createdAt])
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXHAUSTED      // ميزانية مستنفدة
  ENDED
  CANCELLED
}

// ── Commission Splits ──────────────────────────────────────────────────────────

model commission_splits {
  id              String              @id @default(uuid())
  dealId          String
  recipientId     String
  recipientType   String              // AGENT, BROKERAGE, REFERRAL
  percentage      Decimal             @db.Decimal(5, 2)
  amount          Decimal             @db.Decimal(14, 2)
  status          CommissionStatus    @default(PENDING)
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  deal            deals               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  recipient       users               @relation("CommissionRecipient", fields: [recipientId], references: [id])

  @@index([dealId])
  @@index([recipientId])
  @@index([status])
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

// ── Lead Routing ───────────────────────────────────────────────────────────────

model lead_routing_rules {
  id              String   @id @default(uuid())
  organizationId  String   @unique
  strategy        String   @default("manual")  // round_robin, territory, manual, first_to_claim
  config          String?  @db.Text             // JSON: { lastAssignedIndex, excludeInactive, maxLeadsPerAgent }
  enabled         Boolean  @default(true)
  lastAssignedIdx Int      @default(0)          // For round-robin tracking
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    organizations @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ── Tenant Management (Post-Rental Lifecycle) ──────────────────────────────────

model tenancies {
  id              String          @id @default(uuid())
  dealId          String?
  propertyId      String
  tenantId        String          // customerId
  agentId         String
  organizationId  String?
  leaseStart      DateTime
  leaseEnd        DateTime
  monthlyRent     Decimal         @db.Decimal(14, 2)
  securityDeposit Decimal?        @db.Decimal(14, 2)
  status          TenancyStatus   @default(ACTIVE)
  ejarContractNo  String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  property        properties      @relation(fields: [propertyId], references: [id])
  tenant          customers       @relation(fields: [tenantId], references: [id])
  agent           users           @relation("TenancyAgent", fields: [agentId], references: [id])
  rentPayments    rent_payments[]

  @@index([agentId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([status])
  @@index([leaseEnd])
}

model rent_payments {
  id          String            @id @default(uuid())
  tenancyId   String
  amount      Decimal           @db.Decimal(14, 2)
  dueDate     DateTime
  paidDate    DateTime?
  status      RentPaymentStatus @default(PENDING)
  notes       String?
  createdAt   DateTime          @default(now())

  tenancy     tenancies         @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  @@index([tenancyId])
  @@index([dueDate])
  @@index([status])
}

enum TenancyStatus {
  ACTIVE
  EXPIRING      // within 90 days of end
  EXPIRED
  RENEWED
  TERMINATED
}

enum RentPaymentStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  WAIVED
}

// ── Drip Campaign Sequences ─────────────────────────────────────────────────────

model campaign_sequences {
  id          String   @id @default(uuid())
  agentId     String
  name        String
  channel     String   @default("whatsapp")
  steps       String   @db.Text  // JSON array: [{delay: "0d", template: "welcome", message: "..."}, ...]
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  agent       users    @relation("SequenceAgent", fields: [agentId], references: [id])
  enrollments sequence_enrollments[]

  @@index([agentId])
}

model sequence_enrollments {
  id          String   @id @default(uuid())
  sequenceId  String
  leadId      String
  currentStep Int      @default(0)
  nextRunAt   DateTime?
  status      String   @default("ACTIVE")  // ACTIVE, PAUSED, COMPLETED, CANCELLED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sequence    campaign_sequences @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([sequenceId])
  @@index([leadId])
  @@index([status])
  @@index([nextRunAt])
}

// ── Deal Documents ─────────────────────────────────────────────────────────────

model deal_documents {
  id          String   @id @default(uuid())
  dealId      String
  fileName    String
  fileUrl     String
  fileType    String?  // pdf, image, doc
  fileSize    Int?     // bytes
  uploadedBy  String
  notes       String?
  createdAt   DateTime @default(now())

  deal        deals    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  uploader    users    @relation("DocumentUploader", fields: [uploadedBy], references: [id])

  @@index([dealId])
  @@index([uploadedBy])
}

// ── WhatsApp / Omnichannel Inbox Messages ──────────────────────────────────────

model messages {
  id          String   @id @default(uuid())
  leadId      String?
  customerId  String?
  agentId     String
  direction   String   // INBOUND, OUTBOUND
  channel     String   // whatsapp, sms, email
  content     String   @db.Text
  phone       String?
  status      String   @default("SENT")  // SENT, DELIVERED, READ, FAILED
  sentAt      DateTime @default(now())
  deliveredAt DateTime?
  readAt      DateTime?
  metadata    String?  @db.Text  // JSON: whatsapp message id, etc.

  @@index([leadId])
  @@index([customerId])
  @@index([agentId])
  @@index([channel])
  @@index([sentAt])
}

// ── Off-Plan Projects ────────────────────────────────────────────────────────

model projects {
  id              String          @id @default(uuid())
  name            String
  developer       String?
  city            String
  district        String?
  description     String?         @db.Text
  status          String          @default("PLANNING")  // PLANNING, UNDER_CONSTRUCTION, COMPLETED, ON_HOLD
  completionDate  DateTime?
  totalUnits      Int             @default(0)
  agentId         String
  organizationId  String?
  coverImage      String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  units           project_units[]

  @@index([agentId])
  @@index([organizationId])
  @@index([city])
  @@index([status])
}

model project_units {
  id          String   @id @default(uuid())
  projectId   String
  unitNumber  String
  floor       Int?
  type        String?  // apartment, villa, townhouse, etc.
  areaSqm     Decimal? @db.Decimal(10, 2)
  bedrooms    Int?
  bathrooms   Int?
  price       Decimal? @db.Decimal(14, 2)
  status      String   @default("AVAILABLE")  // AVAILABLE, RESERVED, SOLD, BLOCKED
  buyerName   String?
  buyerPhone  String?
  reservedAt  DateTime?
  paymentSchedule String? @db.Text  // JSON: [{milestone, percentage, amount, dueDate, paidDate}]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project     projects @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

// ── Maintenance Request System (Session 5.6) ────────────────────────────────

model maintenance_requests {
  id              String   @id @default(uuid())
  tenancyId       String?
  propertyId      String
  reportedBy      String   // userId or customerId
  category        String   // plumbing, electrical, hvac, general, structural
  description     String   @db.Text
  photos          String?  @db.Text  // JSON array of URLs
  priority        String   @default("MEDIUM")  // LOW, MEDIUM, HIGH, URGENT
  status          String   @default("SUBMITTED")  // SUBMITTED, ASSIGNED, IN_PROGRESS, COMPLETED, CANCELLED
  assignedVendor  String?
  vendorNotes     String?
  completedAt     DateTime?
  cost            Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([propertyId])
  @@index([status])
  @@index([tenancyId])
}

// ── Vendor / Contractor Database (Session 5.7) ──────────────────────────────

model vendors {
  id              String   @id @default(uuid())
  name            String
  phone           String
  email           String?
  specialization  String   // plumbing, electrical, hvac, cleaning, painting, general
  city            String?
  rating          Decimal? @db.Decimal(2, 1)  // 1.0 - 5.0
  isActive        Boolean  @default(true)
  notes           String?
  agentId         String
  organizationId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentId])
  @@index([organizationId])
  @@index([specialization])
}

// ── Viewing Feedback Forms (Session 5.8) ─────────────────────────────────────

model viewing_feedback {
  id                String   @id @default(uuid())
  appointmentId     String   @unique
  customerId        String?
  locationRating    Int?     // 1-5
  conditionRating   Int?     // 1-5
  priceRating       Int?     // 1-5
  overallRating     Int?     // 1-5
  comments          String?
  createdAt         DateTime @default(now())

  @@index([appointmentId])
  @@index([customerId])
}

// ── Land Subdivision ───────────────────────────────────────────────────────────

model land_subdivisions {
  id              String   @id @default(uuid())
  parentPropertyId String
  agentId         String
  organizationId  String?
  totalArea       Decimal  @db.Decimal(14, 2)
  lotCount        Int      @default(0)
  status          String   @default("PLANNING")  // PLANNING, APPROVED, IN_PROGRESS, COMPLETED
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lots            subdivision_lots[]

  @@index([parentPropertyId])
  @@index([agentId])
}

model subdivision_lots {
  id              String   @id @default(uuid())
  subdivisionId   String
  lotNumber       String
  areaSqm         Decimal  @db.Decimal(10, 2)
  price           Decimal? @db.Decimal(14, 2)
  status          String   @default("AVAILABLE")  // AVAILABLE, RESERVED, SOLD
  buyerName       String?
  buyerPhone      String?
  infrastructure  String?  @db.Text  // JSON: { water, electricity, sewage, road }
  createdAt       DateTime @default(now())

  subdivision     land_subdivisions @relation(fields: [subdivisionId], references: [id], onDelete: Cascade)

  @@index([subdivisionId])
  @@index([status])
}

// ── Warranty Tracking ──────────────────────────────────────────────────────────

model property_warranties {
  id          String   @id @default(uuid())
  propertyId  String
  itemName    String   // AC, water heater, elevator, etc.
  brand       String?
  installedAt DateTime?
  expiresAt   DateTime
  vendor      String?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([propertyId])
  @@index([expiresAt])
}
