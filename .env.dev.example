# Development Environment - Copy to .env for local development
# cp .env.dev.example .env

# Database (matches docker-compose.dev and docker-compose.devcontainer)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/real_estate_crm?schema=real_estate_crm"

# Redis (optional - only if using Redis features)
REDIS_URL="redis://localhost:6379"

# Security (use dev values - never in production)
JWT_SECRET="dev-jwt-secret-change-in-production"
SESSION_SECRET="dev-session-secret-change-in-production"

# Server
PORT=3000
NODE_ENV=development

# Optional: Google Maps (for map features)
# VITE_GOOGLE_MAPS_API_KEY=your_key_here
# GOOGLE_MAPS_API_KEY=your_key_here

# CORS (comma-separated allowed origins)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Admin setup (required for initial admin creation endpoint)
ADMIN_SETUP_TOKEN="dev-setup-token-min-32-chars-change-in-prod"

# Landing page preview token
# LANDING_PREVIEW_TOKEN=dev-preview-token

# Optional: Twilio (for SMS notifications in buyer pool)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Optional: GCS Storage (for file uploads)
# GCS_BUCKET_NAME=
# GCS_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Optional: Sentry error tracking
# SENTRY_DSN=

# Feature flags
ALLOW_PRODUCTION_SEED=false
